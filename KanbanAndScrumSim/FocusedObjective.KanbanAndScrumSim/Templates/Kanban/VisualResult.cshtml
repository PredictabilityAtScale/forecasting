@using System.Xml.Linq
@using System.Xml
@{ 
    XElement root = null; 
    XElement stats = null;

    if (!String.IsNullOrEmpty(Context))
    {
        root = XDocument.Parse(Context).Element("results").Element("visual");
        stats = root.Element("statistics");
    }
}
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Focused Objective Kanban Visual Simulation Results</title>
    <script type="text/javascript" src="http://www.google.com/jsapi"></script>
    <script type="text/javascript">
        google.load('visualization', '1', { packages: ['corechart'] });
    </script>
    <script type="text/javascript">
        function drawVisualization() {

            //INSERT DATA HERE 
            @root.Element("cumulativeFlow").Element("chart").Value

            // Create and populate the data table.
            var data = new google.visualization.DataTable();
            data.addColumn('string', 'Interval');
            for (var i = 0; i < columns.length; ++i) {
                data.addColumn('number', columns[i]);
            }

            data.addRows(intervals.length);
            for (var i = 0; i < intervals.length; ++i) {
                data.setCell(i, 0, intervals[i]);
            }

            for (var i = 0; i < columns.length; ++i) {
                var row = countByTimeInterval[i];
                for (var interval = 0; interval < intervals.length; ++interval) {
                    data.setCell(interval, i + 1, row[interval]);
                }
            }

            // Create and draw the visualization.
            var ac = new google.visualization.AreaChart(document.getElementById('visualization'));
            ac.draw(data, {
                title: 'Simulation Cumulative Flow Diagram',
                isStacked: true,
                width: 600,
                height: 400,
                vAxis: { title: "Count of Cards" },
                hAxis: { title: "Time Interval" }
            });
        }

        google.setOnLoadCallback(drawVisualization);
    </script>
       <style type="text/css">
        #box-table-a
        {
            font-family: Arial;
            font-size: 12px;
            margin: 45px;
            width: 500px;
            text-align: center;
            border-collapse: collapse;
        }
        #box-table-a th
        {
            font-size: 12px;
            font-weight: normal;
            padding: 8px;
            background: #b9c9fe;
            border-top: 4px solid #aabcfe;
            border-bottom: 1px solid #fff;
            color: #039;
        }
        #box-table-a td
        {
            padding: 8px;
            background: #e8edff;
            border-bottom: 1px solid #fff;
            color: #669;
            border-top: 1px solid transparent;
        }
        #box-table-a tr:hover td
        {
            background: #d0dafd;
            color: #339;
        }
    </style>
</head>
<body style="font-family: Arial; border: 0 none; font-size: 12px">
    <h2>
        Focused Objective Kanban Visual Simulation Results</h2>
    Simulation took <strong>@stats.Element("intervals").Attribute("value").Value</strong> time intervals to complete all
    backlog, defects and added scope.<br />
    <div id="visualization" style="width: 600px; height: 400px;">
    </div>
