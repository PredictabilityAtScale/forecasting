@using System.Xml.Linq
@using System.Xml
@{ 
    XElement root = null; 
    XElement stats = null;

    if (!String.IsNullOrEmpty(Context))
    {
        root = XDocument.Parse(Context).Element("results").Element("monteCarlo");
        stats = root.Element("statistics");
    }
}
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0 Transitional//EN">
<html>
	<head>
		<title>Focused Objective Kanban Monte-carlo Simulation Results</title>
            <style type="text/css">
        #box-table-a
        {
            font-family: Arial;
            font-size: 12px;
            margin: 45px;
            width: 500px;
            text-align: center;
            border-collapse: collapse;
        }
        #box-table-a th
        {
            font-size: 12px;
            font-weight: normal;
            padding: 8px;
            background: #b9c9fe;
            border-top: 4px solid #aabcfe;
            border-bottom: 1px solid #fff;
            color: #039;
        }
        #box-table-a td
        {
            padding: 8px;
            background: #e8edff;
            border-bottom: 1px solid #fff;
            color: #669;
            border-top: 1px solid transparent;
        }
        #box-table-a tr:hover td
        {
            background: #d0dafd;
            color: #339;
        }
    </style>

	</head>
	<body style="font-family: Arial;border: 0 none; font-size:12px">
    <div>
    <h2>Focused Objective Kanban Monte-carlo Simulation Results</h2>
    <table id="box-table-a" summary="Interval Summary Statistics">
        <thead>
            <tr>
            <th>&nbsp;</th>
            <th>Intervals</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <th>
                    Count
                </th>
                <td>
                    @stats.Element("intervals").Attribute("count").Value
                </td>
            </tr>
            <tr>
                <th>
                    Minimum
                </th>
                <td>
                   @stats.Element("intervals").Attribute("minimum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Average
                </th>
                <td>
                   @stats.Element("intervals").Attribute("average").Value
                </td>
            </tr>
            <tr>
                <th>
                    Maximum
                </th>
                <td>
                   @stats.Element("intervals").Attribute("maximum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Histogram
                </th>
                <td>
                    <a href="@stats.Element("intervals").Element("histogram").Element("chart").Value ">
                        <img src="@stats.Element("intervals").Element("histogram").Element("chart").Value " width="150px" /></a>
                </td>
            </tr>
            </tbody>
            </table>


    <table id="box-table-a" summary="Board Position Summary Statistics">
        <thead>
            <tr>
                <th>
                    &nbsp;
                </th>
                <th>
                    Empty Positions
                </th>
                <th>
                    Queued Positions
                </th>
                <th>
                    Blocked Positions
                </th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th>
                    Count
                </th>
                <td>
                   @stats.Element("emptyPositions").Attribute("count").Value
                </td>
                <td>
                   @stats.Element("queuedPositions").Attribute("count").Value
                </td>
                <td>
                   @stats.Element("blockedPositions").Attribute("count").Value
                </td>
            </tr>
            <tr>
                <th>
                    Minimum
                </th>
                <td>
                   @stats.Element("emptyPositions").Attribute("minimum").Value
                </td>
                <td>
                  @stats.Element("queuedPositions").Attribute("minimum").Value
                </td>
                <td>
                   @stats.Element("blockedPositions").Attribute("minimum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Average
                </th>
                <td>
                   @stats.Element("emptyPositions").Attribute("average").Value
                </td>
                <td>
                   @stats.Element("queuedPositions").Attribute("average").Value
                </td>
                <td>
                   @stats.Element("blockedPositions").Attribute("average").Value
                </td>
            </tr>
            <tr>
                <th>
                    Maximum
                </th>
                <td>
                   @stats.Element("emptyPositions").Attribute("maximum").Value
                </td>
                <td>
                   @stats.Element("queuedPositions").Attribute("maximum").Value
                </td>
                <td>
                   @stats.Element("blockedPositions").Attribute("maximum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Histogram
                </th>
                <td>
                    <a href="@stats.Element("emptyPositions").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("emptyPositions").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
                <td>
                    <a href="@stats.Element("queuedPositions").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("queuedPositions").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
                <td>
                    <a href="@stats.Element("blockedPositions").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("blockedPositions").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
            </tr>
        </tbody>
    </table>
    <table id="box-table-a" summary="Card Type Summary Statistics">
        <thead>
            <tr>
                <th>
                    &nbsp;
                </th>
                <th>
                    Work Cards
                </th>
                <th>
                    Defect Cards
                </th>
                <th>
                    Added Scope
                </th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th>
                    Count Minimum
                </th>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("work").Element("count") != null ? stats.Element("cards").Element("work").Element("count").Attribute("minimum").Value : string.Empty); }
                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("defect").Element("count") != null ? stats.Element("cards").Element("defect").Element("count").Attribute("minimum").Value : string.Empty); }
                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("addedScope").Element("count") != null ? stats.Element("cards").Element("addedScope").Element("count").Attribute("minimum").Value : string.Empty); }
                </td>
            </tr>
            <tr>
                <th>
                    Count Average
                </th>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("work").Element("count") != null ? stats.Element("cards").Element("work").Element("count").Attribute("average").Value : string.Empty); }
                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("defect").Element("count") != null ? stats.Element("cards").Element("defect").Element("count").Attribute("average").Value : string.Empty); }
                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("addedScope").Element("count") != null ? stats.Element("cards").Element("addedScope").Element("count").Attribute("average").Value : string.Empty); }
                </td>
            </tr>
                        <tr>
                <th>
                    Count Maximum
                </th>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("work").Element("count") != null ? stats.Element("cards").Element("work").Element("count").Attribute("maximum").Value : string.Empty); }
                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("defect").Element("count") != null ? stats.Element("cards").Element("defect").Element("count").Attribute("maximum").Value : string.Empty); }

                </td>
                <td>
                   @{ Response.Write(stats.Element("cards").Element("addedScope").Element("count") != null ? stats.Element("cards").Element("addedScope").Element("count").Attribute("maximum").Value : string.Empty); }
                </td>
            </tr>
            <tr>
                <th>
                    Count Histogram
                </th>
                <td>
                    <a href="@{ Response.Write(stats.Element("cards").Element("work").Element("count") != null ? stats.Element("cards").Element("work").Element("count").Element("histogram").Element("chart").Value : string.Empty); }">
                        <img src="@{ Response.Write(stats.Element("cards").Element("work").Element("count") != null ? stats.Element("cards").Element("work").Element("count").Element("histogram").Element("chart").Value : string.Empty); }" width="150px" /></a>
                </td>
                <td>
                    <a href="@{ Response.Write(stats.Element("cards").Element("defect").Element("count") != null ? stats.Element("cards").Element("defect").Element("count").Element("histogram").Element("chart").Value : string.Empty); }">
                        <img src="@{ Response.Write(stats.Element("cards").Element("defect").Element("count") != null ? stats.Element("cards").Element("defect").Element("count").Element("histogram").Element("chart").Value : string.Empty); }" width="150px" /></a>
                </td>
                <td>
                    <a href="@{ Response.Write(stats.Element("cards").Element("addedScope").Element("count") != null ? stats.Element("cards").Element("addedScope").Element("count").Element("histogram").Element("chart").Value : string.Empty); }">
                        <img src="@{ Response.Write(stats.Element("cards").Element("addedScope").Element("count") != null ? stats.Element("cards").Element("addedScope").Element("count").Element("histogram").Element("chart").Value : string.Empty); }" width="150px" /></a>
                </td>
            </tr>
            <tr>
                <th>
                    Cycle-time Minimum
                </th>
                <td>
                   @stats.Element("cards").Element("work").Element("cycleTime").Attribute("minimum").Value
                </td>
                <td>
                   @stats.Element("cards").Element("defect").Element("cycleTime").Attribute("minimum").Value
                </td>
                <td>
                   @stats.Element("cards").Element("addedScope").Element("cycleTime").Attribute("minimum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Cycle-time Average
                </th>
                <td>
                   @stats.Element("cards").Element("work").Element("cycleTime").Attribute("average").Value
                </td>
                <td>
                   @stats.Element("cards").Element("defect").Element("cycleTime").Attribute("average").Value
                </td>
                <td>
                   @stats.Element("cards").Element("addedScope").Element("cycleTime").Attribute("average").Value
                </td>
            </tr>
            <tr>
                <th>
                    Cycle-time Maximum
                </th>
                <td>
                   @stats.Element("cards").Element("work").Element("cycleTime").Attribute("maximum").Value
                </td>
                <td>
                   @stats.Element("cards").Element("defect").Element("cycleTime").Attribute("maximum").Value
                </td>
                <td>
                   @stats.Element("cards").Element("addedScope").Element("cycleTime").Attribute("maximum").Value
                </td>
            </tr>
            <tr>
                <th>
                    Cycle-time Histogram
                </th>
                <td>
                    <a href="@stats.Element("cards").Element("work").Element("cycleTime").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("cards").Element("work").Element("cycleTime").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
                <td>
                    <a href="@stats.Element("cards").Element("defect").Element("cycleTime").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("cards").Element("defect").Element("cycleTime").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
                <td>
                    <a href="@stats.Element("cards").Element("addedScope").Element("cycleTime").Element("histogram").Element("chart").Value">
                        <img src="@stats.Element("cards").Element("addedScope").Element("cycleTime").Element("histogram").Element("chart").Value" width="150px" /></a>
                </td>
            </tr>
        </tbody>
    </table>
    
    </div>
	
	</body>
</html>