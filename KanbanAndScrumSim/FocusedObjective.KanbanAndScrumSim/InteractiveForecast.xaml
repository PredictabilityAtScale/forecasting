<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FocusedObjective.KanbanSim" x:Class="FocusedObjective.KanbanSim.InteractiveForecast" 
        Title="Interactive Forecast (BETA: work in progress)" Width="1000" Height="700" >

    <Window.Resources>
        <DataTemplate x:Key="blankLAbelTemplate">

        </DataTemplate>


        <DataTemplate x:Key="tooltipTemplate">
            <Border BorderBrush="Black" BorderThickness="1">

                <Grid  Height="50">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.5*"/>
                        <RowDefinition Height="0.5*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding CorrespondingPoints[0].DataPoint.Y}" Grid.Row="0" Grid.Column="1"  Grid.ColumnSpan="2" 
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center" TextAlignment="Center"  Foreground="Black" FontSize="16"/>
                    <!--                   <TextBlock VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" 
                                       TextAlignment="Left" Text="Rank :"
                                       HorizontalAlignment="Left" Foreground="Black" FontSize="16"/>
                    <TextBlock VerticalAlignment="Center" Margin="3,3,6,3" Grid.Column="2" Grid.Row="1" 
                                       TextAlignment="Left" Text="{Binding Item.Rank}" 
                                       HorizontalAlignment="Left" Foreground="Black" FontSize="16"/>
                    
                    -->

                </Grid>
            </Border>
        </DataTemplate>

        <ToolTip x:Key="simpleTooltip" Content="{Binding CorrespondingPoints[0].DataPoint.Y}"/>

    </Window.Resources>


    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="1.3*"  />
            <RowDefinition Height="5" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="35" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="35" />
            </Grid.RowDefinitions>

            <Border Background="GhostWhite" BorderBrush="Gainsboro" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Grid.Row="0"  Orientation="Vertical"  >
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontWeight="SemiBold" Grid.Column="0" Padding="5,0,0,0" >Parameter (original value)</TextBlock>
                            <TextBlock FontWeight="SemiBold" Grid.Column="1">Current</TextBlock>
                            <TextBlock FontWeight="SemiBold" Grid.Column="2"></TextBlock>
                        </Grid>

                        <WrapPanel HorizontalAlignment="Left" x:Name="panelParameterControls" Orientation="Horizontal"></WrapPanel>
                        <!-- other controls get added at run-time -->
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--<Button     Grid.Row="1" Content="Recommend" HorizontalAlignment="Right"  Width="75" IsEnabled="False" Margin="0,5,5,5"/>-->
            <Button     Grid.Row="1" x:Name="buttonSimulate" Content="Run forecast trial" HorizontalAlignment="Left" Width="150" Click="buttonSimulate_Click" Margin="5,5,0,5"/>

        </Grid>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" />

        <Grid Grid.Row="2">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" MinWidth="125" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0" x:Name="listResults" SelectionMode="Single" HorizontalAlignment="Stretch" SelectionChanged="listResults_SelectionChanged" />

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <TabControl Grid.Column="2">
                    <TabItem Header="Compare Trials">
                        
                        <Grid>
                            <!--
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="5" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>

                            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                            
                            <!-- A -->
                            
                            <Grid Grid.Row="0">
                                
                                <StackPanel Orientation="Vertical" x:Name="panelA" DataContext="TrialResult">
                                
                                    <ComboBox x:Name="comboA" Height="25" VerticalAlignment="Top" SelectionChanged="comboA_SelectionChanged">
                                        <ComboBoxItem IsSelected="True" >Baseline</ComboBoxItem>
                                        <ComboBoxItem>Selected Trial</ComboBoxItem>
                                        <ComboBoxItem>Last</ComboBoxItem>
                                        <ComboBoxItem>Shortest</ComboBoxItem>
                                        <ComboBoxItem>Earliest</ComboBoxItem>
                                        <ComboBoxItem>Lowest Total Cost</ComboBoxItem>
                                    </ComboBox>



                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Trial:</Label>
                                        <Label x:Name="labelTrialA" />
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Duration:</Label>
                                        <Label x:Name="labelDurationA" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Forecast:</Label>
                                        <Label x:Name="labelForecastA"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Cost:</Label>
                                        <Label x:Name="labelCostA"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Cost of delay:</Label>
                                        <Label x:Name="labelCostOfDelayA"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Total cost:</Label>
                                        <Label x:Name="labelTotalCostA"></Label>
                                    </StackPanel>


                                </StackPanel>
                            </Grid>
                            
                            <!-- B -->
                            <Grid Grid.Row="2">
                                <StackPanel>
                                    
                                <ComboBox x:Name="comboB" Height="25" VerticalAlignment="Top" SelectionChanged="comboB_SelectionChanged">
                                    <ComboBoxItem>Baseline</ComboBoxItem>
                                    <ComboBoxItem>Selected Trial</ComboBoxItem>
                                    <ComboBoxItem IsSelected="True">Last</ComboBoxItem>
                                    <ComboBoxItem>Shortest</ComboBoxItem>
                                    <ComboBoxItem>Earliest</ComboBoxItem>
                                    <ComboBoxItem>Lowest Total Cost</ComboBoxItem>
                                </ComboBox>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Trial:</Label>
                                        <Label x:Name="labelTrialB" />
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Duration:</Label>
                                        <Label x:Name="labelDurationB" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Forecast:</Label>
                                        <Label x:Name="labelForecastB"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Cost:</Label>
                                        <Label x:Name="labelCostB"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Cost of delay:</Label>
                                        <Label x:Name="labelCostOfDelayB"></Label>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label FontWeight="SemiBold">Total cost:</Label>
                                        <Label x:Name="labelTotalCostB"></Label>
                                    </StackPanel>


                                </StackPanel>

                            </Grid>


                        </Grid>
                        
                    </TabItem>
                    
                    <TabItem Header="Chart" > 


                    </TabItem>
                </TabControl>
            </Grid>

        </Grid>


        <Button Grid.Row="5" x:Name="buttonClose" Content="Close" HorizontalAlignment="Right" Margin="5,5,5,5" Width="75" IsCancel="True"/>



    </Grid>
</Window>

    
    