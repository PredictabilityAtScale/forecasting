@using System.Xml.Linq
@using System.Xml
@{ 
    XElement root = null;

    if (!String.IsNullOrEmpty(Context))
    {
        root = XDocument.Parse(Context).Element("results").Element("forecastDate");
    }
}
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0 Transitional//EN">
<html>
	<head>
		<title>Focused Objective Kanban Forecast Date Simulation Results</title>
            <style type="text/css">
        #box-table-a
        {
            font-family: Arial;
            font-size: 12px;
            margin: 20px;
            width: 500px;
            text-align: center;
            border-collapse: collapse;
        }
        #box-table-a th
        {
            font-size: 12px;
            font-weight: normal;
            padding: 8px;
            background: #b9c9fe;
            border-top: 4px solid #aabcfe;
            border-bottom: 1px solid #fff;
            color: #039;
        }
        #box-table-a td
        {
            padding: 8px;
            background: #e8edff;
            border-bottom: 1px solid #fff;
            color: #669;
            border-top: 1px solid transparent;
        }
        #box-table-a tr:hover td
        {
            background: #d0dafd;
            color: #339;
        }
    </style>

	</head>
	<body style="font-family: Arial;border: 0 none; font-size:12px">
    <div>
        <h2>Focused Objective Kanban Forecast Date Simulation Results</h2>

<h3>Settings</h3>
    <table id="box-table-a" summary="Forecast Date Setup">
        <thead>
            <tr>
            <th>&nbsp;</th>
            <th>Value</th>
            </tr>
            </thead>
            <tbody>
            <tr>
                <th>
                    Start date
                </th>
                <td>
                    @root.Attribute("startDate").Value
                </td>
            </tr>
            <tr>
                <th>
                    Intervals to One Day
                </th>
                <td>
                    @root.Attribute("intervalsToOneDay").Value
                </td>
            </tr>
            <tr>
                <th>
                    Work days
                </th>
                <td>
                   @root.Attribute("workdays").Value
                </td>
            </tr>
            <tr>
                <th>
                    Cost per work day
                </th>
                <td>
                    @root.Attribute("costPerDay").Value
                </td>
            </tr>
            </tbody>
            </table>
<h3>Results</h3>
    <table id="box-table-a" summary="Forecasted Dates">
        <thead>
            <tr>
                <th>Likelihood</th>
                <th>Date</th>
                <th>Workdays</th>
                <th>Cost</th>
            </tr>
        </thead>
        <tbody>

            @{
                
                foreach(var date in root.Element("dates").Elements("date"))
                {
                    Response.Write("<tr>");
                 
                    Response.Write("<th>" + date.Attribute("likelihood").Value + "</th>");
                    Response.Write("<td>" + date.Attribute("date").Value + "</td>");
                    Response.Write("<td>" + date.Attribute("workDays").Value + "</td>");
                    Response.Write("<td>" + date.Attribute("cost").Value + "</td>");
                    Response.Write("</tr>");
                }
                 
             }
            </tbody>
            </table>
    </div>
	
	</body>
</html>