<simulation name="Simple test">
  <execute type="Scrum">
    <monteCarlo cycles="1"  />
  </execute>
  <setup>
    <iteration storyPointsPerIterationLowBound="10" storyPointsPerIterationHighBound="10" />
    <backlog type="custom">
      <custom count="100" estimateLowBound="10" estimateHighBound="10">Story {0}</custom>
     </backlog>
    
    <addedScopes>
      <addedScope occurrenceDistribution="occurrence" estimateDistribution="estimate">Added scope</addedScope>
    </addedScopes>

    <distributions>
      <distribution name="occurrence"
                shape="custom"
                parameters="5,1"
                numberType="double"/>

      <distribution name="estimate"
            shape="custom"
            parameters="10,1"
            numberType="double"/>
      
    </distributions>
  </setup>
</simulation>