@using System.Xml.Linq
@using System.Xml
@{ 
    XElement root = null; 
    XElement chart = null;

    if (!String.IsNullOrEmpty(Context))
    {
        root = XDocument.Parse(Context).Element("results").Element("addStaff");
        chart = root.Element("chart");
    }
}
<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.0 Transitional//EN">
<html>
<head>
    <title>Focused Objective Kanban Add Staff Simulation Results</title>
    <style type="text/css">
        #box-table-a
        {
            font-family: Arial;
            font-size: 12px;
            margin: 45px;
            width: 500px;
            text-align: center;
            border-collapse: collapse;
        }
        #box-table-a th
        {
            font-size: 12px;
            font-weight: normal;
            padding: 8px;
            background: #b9c9fe;
            border-top: 4px solid #aabcfe;
            border-bottom: 1px solid #fff;
            color: #039;
        }
        #box-table-a td
        {
            padding: 8px;
            background: #e8edff;
            border-bottom: 1px solid #fff;
            color: #669;
            border-top: 1px solid transparent;
        }
        #box-table-a tr:hover td
        {
            background: #d0dafd;
            color: #339;
        }
    </style>
</head>
<body style="font-family: Arial; border: 0 none; font-size: 12px">
    <div>
        <h2>
            Focused Objective Kanban Add Staff Simulation Results</h2>
        
        
        <table id="box-table-a" summary="Add Staff Charts">
            <thead>
                <tr>
                    <th>
                        Intervals
                    </th>
                    <th>
                        Cycle-time
                    </th>
                    <th>
                        Empty Positions
                    </th>
                    <th>
                        Queued Positions
                    </th>
                </tr>
            </thead>
            <tbody>
                <td>
                    <a href="@chart.Element("intervals").Value">
                        <img src="@chart.Element("intervals").Value" width="150px" />
                </td>
                <td>
                    <a href="@chart.Element("cycleTime").Value">
                        <img src="@chart.Element("cycleTime").Value" width="150px" />
                </td>
                <td>
                    <a href="@chart.Element("emptyPositions").Value">
                        <img src="@chart.Element("emptyPositions").Value" width="150px" />
                </td>
                <td>
                    <a href="@chart.Element("queuedPositions").Value">
                        <img src="@chart.Element("queuedPositions").Value" width="150px" />
                </td>
            </tbody>
        </table>
        <table id="box-table-a" summary="Add staff details">
            <thead>
                <tr>
                    <th>
                        Inc/Dec WIP in Column
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<th>");
                            Response.Write(suggestion.Attribute("columnName").Value);
                            Response.Write("</th>");
                        }
                     }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <th>
                        Original wip
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("originalWip").Value);
                            Response.Write("</td>");
                        }
                     }
                </tr>
                <tr>
                    <th>
                        New wip
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("newWip").Value);
                            Response.Write("</td>");
                        }
                     }
                </tr>
                <tr>
                    <th>
                        Interval Improvement
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("intervalImprovement").Value + "%");
                            Response.Write("</td>");
                        }
                     }                
                </tr>
                <tr>
                    <th>
                        Cycle-time Improvement
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("cycleTimeImprovement").Value + "%");
                            Response.Write("</td>");
                        }
                     } 
                </tr>
                <tr>
                    <th>
                        Empty positions Improvement
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("emptyPositionsImprovement").Value + "%");
                            Response.Write("</td>");
                        }
                     } 
                </tr>
                <tr>
                    <th>
                        Queued positions Improvement
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("queuedPositionsImprovement").Value + "%");
                            Response.Write("</td>");
                        }
                     }
                </tr>
                <tr>
                    <th>
                        Queued & Empty positions Improvement
                    </th>
                    @{
                        foreach(var suggestion in root.Elements("wipSuggestion"))
                        {
                            Response.Write("<td>");
                            Response.Write(suggestion.Attribute("queuedAndEmptyPositionsImprovement").Value + "%");
                            Response.Write("</td>");
                        }
                     }
                  </tr>
            </tbody>
        </table>
    </div>
</body>
</html>
