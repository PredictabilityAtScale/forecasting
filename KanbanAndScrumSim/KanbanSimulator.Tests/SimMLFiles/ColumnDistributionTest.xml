<simulation name="Simple Column Distribution test">
  <execute>
    <visual showVisualizer="false"  />
    <monteCarlo cycles="1"  />
  </execute>
  <setup>
    <backlog type="simple" simpleCount="100" />

    <columns>
      <column id="0" estimateDistribution="col1" wipLimit="1">Column 1</column>
      <column id="1" estimateLowBound="1.2" estimateHighBound="1.2" wipLimit="1">Column 2</column>
      <column id="2" estimateDistribution="col3" wipLimit="1">Column 3</column>
      <column id="3" estimateLowBound="1.4" estimateHighBound="1.4" wipLimit="1">Column 4</column>
      <column id="4" estimateDistribution="col5" wipLimit="1">Column 5</column>
    </columns>

    <distributions>
      <distribution name="col1"
                shape="custom"
                parameters="1.1,1"
                numberType="double"/>

      <distribution name="col3"
                shape="custom"
                parameters="1.3,1"
                numberType="double"/>

      <distribution name="col5"
                shape="custom"
                parameters="1.5,1"
                numberType="double"/>

    </distributions>
  </setup>
</simulation>