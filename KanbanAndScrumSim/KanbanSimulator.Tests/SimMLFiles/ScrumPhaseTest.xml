<simulation name="Scrum Phase Test"  >

  <execute type="Scrum">
    <visual showVisualizer="false"/>
    <monteCarlo cycles="1" />
  </execute>

  <setup>
    <iteration storyPointsPerIterationLowBound="5"  storyPointsPerIterationHighBound="5" />

    <backlog type="custom" shuffle="false">
      <custom name="backlog" count="100" estimateLowBound="1" estimateHighBound="1" />
    </backlog>

    <phases>
      <phase startPercentage="0" endPercentage="20" iterationMultiplier="0.8">phase1</phase>
      <!-- 21 to 30 will be default -->
      <phase startPercentage="30" endPercentage="70">phase2</phase>
      <!-- 71 to 80 will be default -->
      <phase startPercentage="80" endPercentage="100"  iterationMultiplier="0.8">phase3</phase>
    </phases>

  </setup>

</simulation>