<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FocusedObjective.KanbanSim"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        x:Class="FocusedObjective.KanbanSim.StatsWindow"
                 xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"

    
        Title="Statistics" Width="500" Height="400" >

    <Window.Resources>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="tabControl1" Margin="0,0,0,42">
            <TabItem Header="Setup" x:Name="tabItemSetup">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="25" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Data Samples or Distribution Definition" Margin="0,0,0,0" x:Name="label1" />


                    <avalonedit:TextEditor Grid.Row="1" Focusable="True"  ScrollViewer.CanContentScroll="True" x:Name="textBoxData" IsReadOnly="False" ShowLineNumbers="True" SyntaxHighlighting="XML"/>

                    <Button Grid.Row="2" Content="Execute" Height="23" Margin="0,0,0,0" x:Name="buttonExecute" Click="buttonExecute_Click" />


                </Grid>
            </TabItem>
            <TabItem Header="Results" x:Name="tabItemResults">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="currentDataPanel" Orientation="Vertical" DataContext="{Binding CurrentData, RelativeSource={RelativeSource FindAncestor, AncestorLevel=1, AncestorType={x:Type local:StatsWindow}}}">
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Sample Count:" FontWeight="Bold"/>
                                <TextBlock Margin="5" Text="{Binding SampleCount}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Minimum:" FontWeight="Bold"/>
                                <TextBlock Margin="5" Text="{Binding Minimum}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Average:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding Average}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Median:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding Median}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Maximum:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding Maximum}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Standard Deviation:" FontWeight="Bold"/>
                                <TextBlock Margin="5" Text="{Binding StandardDeviation}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="5th %:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding FifthPercentile}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="25th%:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding TwentyFifthPercentile}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="75th%:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding SeventyFifthPercentile}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="95th%:" FontWeight="Bold" />
                                <TextBlock Margin="5" Text="{Binding NinetyFifthPercentile}" />
                            </WrapPanel>
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="5" Text="Distribution:" FontWeight="Bold" />
                                <TextBox Margin="5" Text="{Binding Distribution}" IsReadOnly="True"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Histogram" x:Name="tabItemHistogram">
                <Grid>

                    <lvc:CartesianChart Series="{Binding SeriesCollection}" LegendLocation="Bottom" VerticalAlignment="Stretch">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Title="Bin" Labels="{Binding Labels}"></lvc:Axis>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Frequency" LabelFormatter="{Binding Formatter}"></lvc:Axis>
                            <lvc:Axis Title="Cumulative Prob" Position="RightTop" LabelFormatter="{Binding SecondaryFormatter}" ></lvc:Axis>
                        </lvc:CartesianChart.AxisY>

                    </lvc:CartesianChart>

                </Grid>
            </TabItem>
            
            <TabItem Header="Random Numbers" x:Name="tabItemRandomNumbers">
                <Grid>
                    <avalonedit:TextEditor Focusable="True"  ScrollViewer.CanContentScroll="True" x:Name="textBoxRandomNumbers" IsReadOnly="True" ShowLineNumbers="True"/>
                </Grid>
            </TabItem>


        </TabControl>
        <Button Content="Close" Height="23" HorizontalAlignment="Right" Margin="0,0,5,12" x:Name="buttonClose" VerticalAlignment="Bottom" Width="75" Click="buttonClose_Click" />
    </Grid>
</Window>
