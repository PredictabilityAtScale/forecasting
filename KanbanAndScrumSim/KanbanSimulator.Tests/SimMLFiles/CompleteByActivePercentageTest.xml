<simulation name="Exit Test" locale="en-US">

  <execute dateFormat="dd-MMM-yyyy" completePercentage="50" activePositionsCompletePercentage="50">
    <visual />
  </execute>

  <setup>
    <!-- start by putting 50 items into the backlog -->
    <backlog type="simple" simpleCount="100" />

    <!-- defined three columns -->
    <columns>
      <column id="1" estimateLowBound="1" estimateHighBound="1" wipLimit="2">Design</column>
      <column id="2" estimateLowBound="1" estimateHighBound="1" wipLimit="4" displayWidth="2">Development</column>
      <column id="3" estimateLowBound="1" estimateHighBound="1" wipLimit="2">Test</column>
    </columns>

    <phases unit="interval">
      <phase start="0" end="10">Phase1</phase>
      <phase start="11" end="29">Phase2</phase>
      <phase start="30" end="100">
        Phase3
        <column id="3" wipLimit="20" />
      </phase>
    </phases>

    <forecastDate startDate="01-May-2012" costPerDay="2500" />

  </setup>
</simulation>
