<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chart="http://schemas.syncfusion.com/wpf" x:Class="FocusedObjective.KanbanSim.AddStaff"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    
        Title="Add Staff" Height="300" Width="300" Loaded="Window_Loaded">
    <Grid>
        <TabControl x:Name="tabControl" Margin="0,0,0,43">

            <TabItem Header="Setup" x:Name="tabItemSetup" >
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="41*"/>
                        <ColumnDefinition Width="8*"/>
                    </Grid.ColumnDefinitions>

                    <xctk:IntegerUpDown x:Name="upDownCount" Minimum="-1000" Maximum="+1000" Value="5"  Width="131" Height="23" Margin="0,18,7,0" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.ColumnSpan="2"/>

                    <ComboBox x:Name="comboLowest" Height="23" HorizontalAlignment="Right" Margin="0,46,7,0" VerticalAlignment="Top" Width="131" Grid.ColumnSpan="2" >
                        <ComboBoxItem Content="Intervals" IsSelected="True" />
                        <ComboBoxItem Content="Cycle-Time" />
                        <ComboBoxItem Content="Empty Positions" />
                        <ComboBoxItem Content="Queued Positions" />
                        <ComboBoxItem Content="Queued and Empty Positions" />
                    </ComboBox>
                    <Button Content="Execute" Margin="7,0,7,6" x:Name="buttonExecute" Height="23" VerticalAlignment="Bottom" Click="buttonExecute_Click" Grid.ColumnSpan="2" />
                    <Label Content="Count (+ or -)" Height="28" HorizontalAlignment="Left" Margin="6,15,0,0" Name="label1" VerticalAlignment="Top" />
                    <Label Content="For Lowest" Height="28" HorizontalAlignment="Left" Margin="7,46,0,0" x:Name="label3" VerticalAlignment="Top" />
                    <CheckBox Content="Or, use the model addStaff command" HorizontalAlignment="Left" Margin="7,0,0,44" x:Name="checkBoxUseModel" Height="16" VerticalAlignment="Bottom" />
                </Grid>
            </TabItem>


            <TabItem Header="Results" x:Name="tabItemResults">
                <Grid>
                    <ScrollViewer>
                        <StackPanel x:Name="stackPanelResults" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <DataGrid AutoGenerateColumns="False" x:Name="dataGridResults" ItemsSource="{Binding Elements[wipSuggestion]}" MinColumnWidth="50" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn  Binding="{Binding Attribute[index].Value}" Header="Order" />
                                    <DataGridTextColumn  Binding="{Binding Attribute[columnName].Value}" Header="Column" />
                                    <DataGridTextColumn Binding="{Binding Attribute[originalWip].Value}" Header="Original WIP" />
                                    <DataGridTextColumn Binding="{Binding Attribute[newWip].Value}" Header="New WIP" />


                                    <DataGridTextColumn Binding="{Binding Attribute[intervalImprovement].Value}" Header="Interval %" />
                                    <DataGridTextColumn Binding="{Binding Attribute[cycleTimeImprovement].Value}" Header="Cycle-Time %" />
                                    <DataGridTextColumn Binding="{Binding Attribute[emptyPositionsImprovement].Value}" Header="Empty Positions %" />
                                    <DataGridTextColumn Binding="{Binding Attribute[queuedPositionsImprovement].Value}" Header="Queued Positions %" />
                                    <DataGridTextColumn Binding="{Binding Attribute[queuedAndEmptyPositionsImprovement].Value}" Header="Queued + Empty Positions %" />

                                    <DataGridTextColumn Binding="{Binding Attribute[newMinimumActiveStaff].Value}" Header="Col Staff Min" />
                                    <DataGridTextColumn Binding="{Binding Attribute[newAverageActiveStaff].Value}" Header="Col Staff Avg" />
                                    <DataGridTextColumn Binding="{Binding Attribute[newMaximumActiveStaff].Value}" Header="Col Staff Max" />

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <!--
            <TabItem Header="Charts" Name="tabItemCharts">
                <Grid />
            </TabItem>
            -->
        </TabControl>
        <Button Content="Close" Height="23" HorizontalAlignment="Right" Margin="0,0,12,12" x:Name="buttonClose" VerticalAlignment="Bottom" Width="75" Click="buttonClose_Click" />
        <Label  Visibility="Hidden" Content="Tips..." HorizontalAlignment="Left" Margin="9,0,0,6" x:Name="labelTip" Width="126" Height="30" VerticalAlignment="Bottom" FontStyle="Oblique" Foreground="Blue" />
        <Button x:Name="buttonAsHTML"  Content="As XML..." HorizontalAlignment="Left" Margin="5,0,0,12" Width="75" Height="23" VerticalAlignment="Bottom" Click="buttonAsHTML_Click" />
    </Grid>
</Window>
