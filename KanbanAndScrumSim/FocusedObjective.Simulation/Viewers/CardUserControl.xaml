<UserControl x:Class="FocusedObjective.Simulation.Viewers.CardUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="100">
    <Grid>

        <Image Name="emptyImage"  Visibility="Hidden" Canvas.Left="0" Canvas.Top="0" Height="100" Stretch="Fill" Width="100" Source="/FocusedObjective.Simulation;component/Viewers/images/empty.png" />
        <Image Name="emptyBufferImage" Visibility="Hidden"  Canvas.Left="0" Canvas.Top="0" Height="100" Stretch="Fill" Width="100" Source="/FocusedObjective.Simulation;component/Viewers/images/empty_buffer.png" />
        
        <Canvas MinWidth="100" MinHeight="100" Name="cardCanvas">

            <Image Name="backgroundImage" Canvas.Left="0" Canvas.Top="0" Height="100" Stretch="Fill" Width="100" Source="/FocusedObjective.Simulation;component/Viewers/images/yellow_initial_2.png" />
                
            <TextBlock Name="textAreaHeader" Height="36" Width="88" Canvas.Left="6" Canvas.Top="6" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" TextAlignment="Center" FontWeight="Bold">Header</TextBlock>
            <TextBlock Name="textAreaDetail" Height="60" Width="100" Canvas.Left="0" Canvas.Top="40" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Stretch" TextAlignment="Center">Detail</TextBlock>

            <Image Name="cosImage" Visibility="Hidden" Canvas.Left="84" Canvas.Top="0" Source="/FocusedObjective.Simulation;component/Viewers/images/FavoriteStar_16x16.png" />

        </Canvas>
        
        
    </Grid>
</UserControl>
