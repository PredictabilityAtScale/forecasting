<Window x:Class="FocusedObjective.KanbanSim.RealTimeSimulation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RealTimeSimulation" Height="400" Width="600">
    <Grid>
        <TabControl Height="147" Name="tabControl1" VerticalAlignment="Top">
            <TabItem Header="Columns" Name="tabItem1">
                <Grid>
                    <ListBox Height="100" HorizontalAlignment="Left" Margin="6,9,0,0" Name="listBox1" VerticalAlignment="Top" Width="104" />
                    <Button Content="Double" Height="23" HorizontalAlignment="Left" Margin="186,52,0,0" Name="button4" VerticalAlignment="Top" Width="50" />
                    <Button Content="Original" Height="23" HorizontalAlignment="Left" Margin="130,83,0,0" Name="button5" VerticalAlignment="Top" Width="108" />
                    <Button Content="Halve" Height="23" HorizontalAlignment="Left" Margin="131,52,0,0" Name="button6" VerticalAlignment="Top" Width="50" />
                    <Label Content="WIP Limit" Height="28" HorizontalAlignment="Left" Margin="130,28,0,0" Name="label2" VerticalAlignment="Top" Width="106" />
                </Grid>
            </TabItem>
            <TabItem Header="Defects" Name="tabItem2">
                <Grid>
                    <ListBox Height="100" HorizontalAlignment="Left" Margin="7,7,0,0" Name="listBox2" VerticalAlignment="Top" Width="103" />
                    <CheckBox Content="Disable" Height="16" HorizontalAlignment="Left" Margin="133,7,0,0" Name="checkBox1" VerticalAlignment="Top" />
                    <Button Content="Double" Height="23" HorizontalAlignment="Left" Margin="189,53,0,0" Name="button1" VerticalAlignment="Top" Width="50" />
                    <Button Content="Original" Height="23" HorizontalAlignment="Left" Margin="133,84,0,0" Name="button2" VerticalAlignment="Top" Width="108" />
                    <Button Content="Halve" Height="23" HorizontalAlignment="Left" Margin="134,53,0,0" Name="button3" VerticalAlignment="Top" Width="50" />
                    <Label Content="Occurrence Rate" Height="28" HorizontalAlignment="Left" Margin="133,29,0,0" Name="label1" VerticalAlignment="Top" Width="106" />
                </Grid>
            </TabItem>
            <TabItem Header="Added Scope" Name="tabItem3">
                <Grid />
            </TabItem>
            <TabItem Header="Blockers" Name="tabItem4">
                <Grid>
                    <StackPanel Height="110" HorizontalAlignment="Left" Margin="0,122,0,0" Name="stackPanel1" VerticalAlignment="Top" Width="271" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
